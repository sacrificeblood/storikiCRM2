# Postgres connection string from your free database provider (Neon, Supabase, ElephantSQL, etc.)
DATABASE_URL=postgres://user:password@host:5432/dbname

# A long random string — used to sign login sessions. Generate one with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string

# Optional: if set, registration requires this code (share it only with your team).
# Leave blank to allow open registration (not recommended for a public URL).
INVITE_CODE=

# Render/most hosts set this automatically — leave as is
NODE_ENV=production
PORT=3000
